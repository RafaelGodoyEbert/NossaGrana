rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funções Auxiliares ---
    function isLoggedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário pertence à família do documento
    function isFamilyMember(familyId) {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId;
    }

    // --- Usuários ---
    match /users/{userId} {
      allow read: if isLoggedIn() && request.auth.uid == userId;
      allow write: if isLoggedIn() && request.auth.uid == userId;
    }

    // --- Famílias ---
    match /families/{familyId} {
      allow read: if isFamilyMember(familyId);
      allow create: if isLoggedIn();
      allow update: if isFamilyMember(familyId);
    }

    // --- Transações (compartilhadas por familyId) ---
    match /transactions/{docId} {
      allow read: if isFamilyMember(resource.data.familyId);
      allow create: if isLoggedIn() && isFamilyMember(request.resource.data.familyId);
      allow update, delete: if isFamilyMember(resource.data.familyId);
    }

    // --- Contas ---
    match /accounts/{docId} {
      allow read: if isFamilyMember(resource.data.familyId);
      allow create: if isLoggedIn() && isFamilyMember(request.resource.data.familyId);
      allow update, delete: if isFamilyMember(resource.data.familyId);
    }

    // --- Orçamentos ---
    match /budgets/{docId} {
      allow read: if isFamilyMember(resource.data.familyId);
      allow create: if isLoggedIn() && isFamilyMember(request.resource.data.familyId);
      allow update, delete: if isFamilyMember(resource.data.familyId);
    }

    // --- Metas ---
    match /goals/{docId} {
      allow read: if isFamilyMember(resource.data.familyId);
      allow create: if isLoggedIn() && isFamilyMember(request.resource.data.familyId);
      allow update, delete: if isFamilyMember(resource.data.familyId);
    }
  }
}
